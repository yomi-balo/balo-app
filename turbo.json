{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AXIOM_DATASET",
    "AXIOM_TOKEN",
    "CI",
    "CORS_ORIGIN",
    "DATABASE_URL",
    "LOG_LEVEL",
    "NEXT_RUNTIME",
    "NODE_ENV",
    "PORT",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "STRIPE_PUBLISHABLE_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "VERCEL_GIT_COMMIT_REF",
    "VERCEL_GIT_COMMIT_SHA",
    "WORKOS_API_KEY",
    "WORKOS_CLIENT_ID",
    "WORKOS_COOKIE_PASSWORD",
    "npm_package_version",
    "AIRWALLEX_ENV",
    "AIRWALLEX_API_BASE_DEMO",
    "AIRWALLEX_API_BASE_PROD",
    "AIRWALLEX_CLIENT_ID_DEMO",
    "AIRWALLEX_CLIENT_ID_PROD",
    "AIRWALLEX_API_KEY_DEMO",
    "AIRWALLEX_API_KEY_PROD",
    "PAYOUT_ENCRYPTION_KEY",
    "INTERNAL_API_SECRET",
    "API_URL",
    "REDIS_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_URL",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST",
    "BREVO_API_KEY",
    "BREVO_SMS_SENDER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
