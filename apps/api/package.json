{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@balo/analytics": "workspace:*",
    "@balo/db": "workspace:*",
    "@balo/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@getbrevo/brevo": "^5.0.1",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sentry/node": "^10.36.0",
    "@types/react": "19.2.2",
    "bullmq": "^5.70.4",
    "fastify": "^5.7.1",
    "ioredis": "^5.9.3",
    "jose": "^6.2.2",
    "libphonenumber-js": "^1.12.40",
    "lodash": "^4.17.23",
    "react": "^19.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
