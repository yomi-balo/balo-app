# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/balo

# ── Redis / BullMQ ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (WorkOS) ────────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ── Email (Brevo + React Email) ──────────────────────────────────
BREVO_API_KEY=              # Brevo transactional email API key
BREVO_SENDER_EMAIL=notifications@balo.expert  # From address for all outbound email
BREVO_SMS_SENDER=Balo             # SMS sender name (max 11 alphanumeric chars)

# ── Analytics (PostHog) ─────────────────────────────────────────
POSTHOG_API_KEY=                # PostHog project API key (server-side; omit to disable)
POSTHOG_HOST=https://app.posthog.com

# ── Analytics (PostHog) ─────────────────────────────────────────
POSTHOG_API_KEY=                # PostHog project API key (server-side; omit to disable)
POSTHOG_HOST=https://app.posthog.com

# ── Expert Search (BAL-246) ──────────────────────────────────────
# Availability gate for GET /experts/search. 'on' hides experts without a future
# availability slot; anything else (unset/'off') shows all searchable, approved
# experts. Leave unset/off in dev + test; set 'on' in Railway prod before the
# BAL-80 DNS cutover.
EXPERT_SEARCH_AVAILABILITY_GATE=off

# ── Display FX (ExchangeRate-API — BAL-380) ──────────────────────
# Presentation-only AUD→GBP/EUR/USD quotes for the daily fx-display-rate sweep.
# NEVER enters balance/settlement math (ADR-1040 invariant #8). Absent key → the sweep
# warns and skips (last-good rows retained; never crashes the cron).
EXCHANGERATE_API_KEY=            # ExchangeRate-API v6 key (server-side; omit to disable the FX sweep)
EXCHANGERATE_API_URL=https://v6.exchangerate-api.com/v6  # Optional base override (tests/staging)

# ── Payments (Stripe) — client charges only (ADR-1041) ───────────
# Single-var topology (ADR-1026 / BAL-382): the VALUE differs per env — test-mode below
# prod, live in prod — set in Railway/Vercel. No _PROD/_TEST branching in code.
STRIPE_SECRET_KEY=            # sk_test_… in dev/staging, sk_live_… in prod
STRIPE_PUBLISHABLE_KEY=       # pk_test_… / pk_live_… (frontend / consumer lane — BAL-377)
STRIPE_WEBHOOK_SECRET=        # whsec_… — per endpoint, per env (each endpoint has its own)

# ── App ──────────────────────────────────────────────────────────
APP_URL=https://balo.expert  # Base URL used in email links (override per environment)
NODE_ENV=development
