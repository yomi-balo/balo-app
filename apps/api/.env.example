# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/balo

# ── Redis / BullMQ ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (WorkOS) ────────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ── Email (Brevo + React Email) ──────────────────────────────────
BREVO_API_KEY=              # Brevo transactional email API key
BREVO_SENDER_EMAIL=notifications@balo.expert  # From address for all outbound email

# ── App ──────────────────────────────────────────────────────────
APP_URL=https://balo.expert  # Base URL used in email links (override per environment)
NODE_ENV=development
